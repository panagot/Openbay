# Optional: Google Maps for the live map view (heatmap + markers).
# Without this, the app uses a built-in mock map (no API key required).
# Get a key: https://console.cloud.google.com/apis/credentials
# Enable: Maps JavaScript API, and optionally Maps SDK for Android if needed.
VITE_GOOGLE_MAPS_API_KEY=

# Optional: X1 EcoChain (see https://x1ecochain.com/)
# VITE_X1_CHAIN_ID=2024
# VITE_X1_RPC=https://testnet.x1ecochain.com
# VITE_X1_EXPLORER=https://maculatus-scan.x1eco.com/
